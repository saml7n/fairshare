# FairShare configuration
# Copy to .env.local and fill in values

# Required: used as admin password and JWT signing key.
# Generate with: python3 -c "import secrets; print(secrets.token_urlsafe(32))"
FAIRSHARE_SECRET_KEY=change-me-to-a-strong-random-string

# Optional: separate JWT signing secret (falls back to FAIRSHARE_SECRET_KEY)
JWT_SECRET=

# Database — overridden by docker-compose.yml to use the named volume
DATABASE_URL=sqlite:///./fairshare.db

# Server
PORT=3000

# Invite code required at registration.
# Leave empty to disable registration entirely.
# Share this with your friends — after 5 wrong guesses/hour per IP, the endpoint is locked out.
REGISTRATION_INVITE_CODE=

# Public tunnel (optional). Leave blank to run locally without a public URL.
# Free account gives you one static domain — your URL never changes.
NGROK_AUTHTOKEN=
NGROK_DOMAIN=       # e.g. yourapp.ngrok-free.app (optional, uses random URL if unset)

# Comma-separated allowed CORS origins (dev only — not needed for Docker builds).
ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:8080
